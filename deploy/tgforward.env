# /etc/tgforward/tgforward.env
# Bu faylni to'ldiring. chmod 600 qiling!

# PostgreSQL
DB_USERNAME=tgforward
DB_PASSWORD=KUCHLI_PAROL_YOZING

# Redis (parolsiz bo'lsa bo'sh qoldiring)
REDIS_PASSWORD=

# Telegram Bot (BotFather dan olinadi)
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ
TELEGRAM_BOT_USERNAME=my_forward_bot

# TDLight (MTProto) — https://my.telegram.org dan olinadi
TDLIGHT_API_ID=12345678
TDLIGHT_API_HASH=abcdef1234567890abcdef1234567890
TDLIGHT_SESSIONS_DIR=/var/lib/tgforward/sessions

# JWT (kamida 32 belgi, random string)
# Yaratish: openssl rand -hex 32
JWT_SECRET=replace_this_with_openssl_rand_hex_32_output
